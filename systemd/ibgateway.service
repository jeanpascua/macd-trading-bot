[Unit]
Description=Interactive Brokers Gateway (via IBC)
After=xvfb.service
Requires=xvfb.service

[Service]
Type=simple
Environment=DISPLAY=:10
WorkingDirectory=/home/jean/ibc
ExecStart=/bin/bash /home/jean/ibc/gatewaystart.sh -inline
Restart=always
RestartSec=30

[Install]
WantedBy=default.target
